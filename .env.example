# Docker Compose 使用（复制为项目根目录 .env）
# 本地 npm run dev 请改用 apps/api/.env.example → apps/api/.env

DB_USER=exam
DB_PASSWORD=changeme
DB_NAME=shangan
DATABASE_URL=postgresql://exam:changeme@db:5432/shangan

JWT_SECRET=your-random-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

DEEPSEEK_API_KEY=sk-你的真实密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com

NODE_ENV=production

# Next.js 容器内代理 API（docker compose 构建 web 时使用）
# API_INTERNAL_URL=http://api:3001

# 本地开发：允许手机/LAN 访问 Next dev（可选，未设置时会自动检测）
# DEV_ALLOWED_ORIGINS=192.168.104.83
