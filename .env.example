# Docker Compose 生产部署（阿里云等项目根目录 .env）
# 复制: cp .env.example .env

DB_USER=exam
DB_PASSWORD=请改成强密码
DB_NAME=shangan
DATABASE_URL=postgresql://exam:请改成强密码@db:5432/shangan

JWT_SECRET=请用-openssl-rand-base64-32-生成
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

DEEPSEEK_API_KEY=sk-你的真实密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com

NODE_ENV=production

# Nginx 配置：首次部署用 http，证书申请成功后改为 https
NGINX_CONF=./docker/nginx/nginx.http.conf
# NGINX_CONF=./docker/nginx/nginx.https.conf

# HTTP 阶段 false；切换 nginx.https.conf 后改为 true
COOKIE_SECURE=false

APP_PUBLIC_URL=https://www.lwywywl.icu

# 忘记密码：发件账号任选其一；收件可以是任意用户注册邮箱
# ./scripts/configure-smtp.sh
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=发件邮箱@qq.com
# SMTP_PASS=SMTP授权码
# SMTP_FROM=发件邮箱@qq.com
