# 本地 npm run dev 使用（复制为 apps/api/.env）
DATABASE_URL=postgresql://exam:password@localhost:5432/shangan
JWT_SECRET=your-random-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
DEEPSEEK_API_KEY=sk-你的真实密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com
NODE_ENV=development
PORT=3001
# 仅 HTTPS 部署时设为 true；HTTP 阶段必须 false 否则浏览器不写 Cookie、无法登录
COOKIE_SECURE=false
