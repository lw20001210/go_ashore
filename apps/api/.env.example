# 本地 npm run dev 使用（复制为 apps/api/.env）
DATABASE_URL=postgresql://exam:password@localhost:5432/shangan
JWT_SECRET=your-random-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
DEEPSEEK_API_KEY=sk-你的真实密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com
NODE_ENV=development
PORT=3001
# 仅 HTTPS 部署时设为 true；HTTP 阶段必须 false 否则浏览器不写 Cookie、无法登录
COOKIE_SECURE=false

# 忘记密码邮件中的前端地址（生产填 https://www.lwywywl.icu）
APP_PUBLIC_URL=http://localhost:3000

# 忘记密码发信：只需 1 个发件邮箱；用户注册邮箱可以是 QQ/Gmail/163 等任意地址
# 运行 ./scripts/configure-smtp.sh 可交互配置
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=发件邮箱@qq.com
# SMTP_PASS=邮箱SMTP授权码（不是登录密码）
# SMTP_FROM=发件邮箱@qq.com
